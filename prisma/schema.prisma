generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id                String          @id @default(cuid())
  userId            String
  serviceProviderId String
  name              String
  model             String
  role              String
  order             Int             @default(0)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now())
  gpuPromptVariant  String?
  systemPrompt      String?
  cyclePromptDelta   String?  // Accumulated prompt modifications from self-evolution cycles
  cycleGpuPromptDelta String? // Accumulated GPU prompt modifications from self-evolution cycles
  ServiceProvider   ServiceProvider @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  User              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Technique {
  id             String   @id @default(cuid())
  userId         String
  spaceId        String
  cycleNumber    Int
  name           String   // e.g., "gradient latent diffusion consensus"
  description    String   // What this technique does
  embedding      String?  // Vector embedding (stored as JSON string)
  avgGrade       Float    // Average grade of experiments using this technique
  successCount   Int      // How many times this worked
  failureCount   Int      // How many times this failed
  experimentIds  String   // JSON array of experiment IDs that used this technique
  createdAt      DateTime @default(now())
  Space          Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FailedApproach {
  id             String   @id @default(cuid())
  userId         String
  spaceId        String
  cycleNumber    Int
  description    String   // What was tried and failed
  failureMode    String   // Classification: MODE_COLLAPSE, GRADIENT_EXPLOSION, WRONG_DIRECTION, etc.
  severity       Float    // 0-1, how critical the failure was
  experimentIds  String   // JSON array of experiment IDs that failed this way
  warningText    String   // Specific warning to include in next proposition/planning
  embedding      String?  // Vector embedding for similarity matching
  createdAt      DateTime @default(now())
  Space          Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Breakthrough {
  id          String   @id @default(cuid())
  userId      String?
  spaceId     String
  title       String
  description String
  category    String
  confidence  Float
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  Space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  User        User?    @relation(fields: [userId], references: [id])
}

model EmbeddingProvider {
  id          String   @id @default(cuid())
  userId      String
  provider    String
  name        String
  apiKey      String
  apiEndpoint String?
  model       String
  dimensions  Int?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Experiment {
  id          String   @id @default(cuid())
  userId      String?
  spaceId     String
  phase       String
  agentId     String
  agentName   String
  prompt      String
  response    String?
  tokensUsed  Int      @default(0)
  cost        Float    @default(0)
  status      String   @default("PENDING")
  result      String?
  metrics     String?
  grade       Float?
  feedback    String?
  userRating  String?
  cycleNumber Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  User        User?    @relation(fields: [userId], references: [id])
}

model ModelCache {
  id          String   @id @default(cuid())
  spaceId     String
  fileName    String
  filePath    String
  fileSize    Int
  downloadUrl String?
  checksum    String?
  description String?
  createdAt   DateTime @default(now())
  Space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model ServiceProvider {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  name      String
  apiKey    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  Agent     Agent[]
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Space {
  id                     String         @id @default(cuid())
  userId                 String
  name                   String
  description            String?
  initialPrompt          String
  status                 String         @default("INITIALIZING")
  currentPhase           String         @default("PLANNING")
  totalTokens            Int            @default(0)
  totalCost              Float          @default(0)
  useEmbeddings          Boolean        @default(false)
  useGpu                 Boolean        @default(false)
  currentCycle           Int            @default(1)
  setupStatus            String?
  setupError             String?
  setupStep              String?
  defaultNumVariants     Int            @default(3)
  defaultStepsPerVariant Int            @default(25)
  numVariantsMode        String         @default("fixed")
  stepsPerVariantMode    String         @default("fixed")
  createdAt              DateTime       @default(now())
  updatedAt              DateTime
  Breakthrough           Breakthrough[]
  Experiment             Experiment[]
  ModelCache             ModelCache[]
  Technique              Technique[]
  FailedApproach         FailedApproach[]
  User                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  Variant                Variant[]
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @default(now())
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  password          String
  username          String              @unique
  role              String              @default("USER")
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @default(now())
  Agent             Agent[]
  Breakthrough      Breakthrough[]
  EmbeddingProvider EmbeddingProvider[]
  Experiment        Experiment[]
  ServiceProvider   ServiceProvider[]
  Space             Space[]
  Technique         Technique[]
  FailedApproach    FailedApproach[]
}

model Variant {
  id             String        @id @default(cuid())
  spaceId        String
  stageId        String
  stageName      String
  cycleNumber    Int           @default(1)
  name           String
  description    String?
  grade          Float?
  feedback       String?
  userRating     String?
  isSelected     Boolean       @default(false)
  order          Int           @default(0)
  status         String        @default("PENDING")
  failureMode    String?
  approachVerdict String?
  gradingWarning  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  cacheDownloads String?
  Space          Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  VariantStep    VariantStep[]
}

model VariantStep {
  id          String   @id @default(cuid())
  variantId   String
  name        String
  description String?
  order       Int      @default(0)
  result      String?
  grade       Float?
  feedback    String?
  userRating  String?
  status      String   @default("PENDING")
  isAuto      Boolean  @default(true)
  autoConfig  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Variant     Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
}
