generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(uuid())
  email            String              @unique
  password         String
  username         String              @unique
  role             String              @default("USER")
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  serviceProviders ServiceProvider[]
  embeddingProviders EmbeddingProvider[]
  agents           Agent[]
  spaces           Space[]
  experiments      Experiment[]
  breakthroughs    Breakthrough[]
}

model ServiceProvider {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   // openai, anthropic, google, openrouter, minimax
  name        String   // Display name
  apiKey      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agents      Agent[]

  @@unique([userId, provider])
}

model EmbeddingProvider {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider    String   // openai, azure, google, cohere, huggingface
  name        String   // Display name
  apiKey      String
  apiEndpoint String?  // For Azure or custom endpoints
  model       String   // e.g. text-embedding-3-small, embedding-001, embed-english-v3.0
  dimensions  Int?     // Output dimensions (for OpenAI 3-series)
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, provider])
}

model Agent {
  id                 String           @id @default(uuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceProviderId  String
  serviceProvider    ServiceProvider  @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  name               String
  model              String
  role               String
  order              Int              @default(0)
  isActive           Boolean          @default(true)
  systemPrompt       String?          // Custom system prompt (overrides hardcoded stage prompt)
  gpuPromptVariant   String?          // Separate prompt variant when useGpu=true
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Space {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  initialPrompt   String
  status          String       @default("INITIALIZING")
  currentPhase    String       @default("PLANNING")
  totalTokens     Int          @default(0)
  totalCost       Float        @default(0)
  useEmbeddings   Boolean      @default(false)
  useGpu         Boolean      @default(false)
  currentCycle    Int          @default(1)
  setupStatus     String?      // 'PENDING', 'RUNNING', 'COMPLETED', 'FAILED' — set during thinking_setup
  setupError      String?      // Last error encountered during thinking_setup
  setupStep       String?      // Human-readable step description for UI progress
  experiments     Experiment[]
  breakthroughs   Breakthrough[]
  variants        Variant[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Variant {
  id           String        @id @default(uuid())
  spaceId      String
  space        Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  stageId      String
  stageName    String
  cycleNumber  Int           @default(1)
  name         String
  description  String?
  grade        Float?
  feedback     String?
  userRating   String?       // thumbs_up or thumbs_down
  isSelected   Boolean       @default(false)
  order        Int           @default(0)
  status       String        @default("PENDING") // PENDING, RUNNING, COMPLETED, FAILED
  steps        VariantStep[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model VariantStep {
  id          String   @id @default(uuid())
  variantId   String
  variant     Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  order      Int      @default(0)
  result     String?
  grade      Float?
  feedback   String?
  userRating String?  // thumbs_up or thumbs_down
  status     String   @default("PENDING") // PENDING, RUNNING, COMPLETED, SKIPPED, FAILED
  isAuto     Boolean  @default(true)
  autoConfig String?  // JSON string for autoConfig
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Experiment {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  spaceId      String
  space        Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  phase        String
  agentId      String
  agentName    String
  prompt       String
  response     String?
  tokensUsed   Int      @default(0)
  cost         Float    @default(0)
  status       String   @default("PENDING")
  result       String?
  metrics      String?
  grade        Float?
  feedback     String?
  userRating   String?  // thumbs_up or thumbs_down
  cycleNumber  Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Breakthrough {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  spaceId     String
  space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title       String
  description String
  category    String
  confidence  Float
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model SystemConfig {
  id            String  @id @default(uuid())
  key           String  @unique
  value         String
  description   String?
  updatedAt     DateTime @updatedAt
}
