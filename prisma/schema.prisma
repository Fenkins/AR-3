generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id                String          @id
  userId            String
  serviceProviderId String
  name              String
  model             String
  role              String
  order             Int             @default(0)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  gpuPromptVariant  String?
  systemPrompt      String?
  ServiceProvider   ServiceProvider @relation(fields: [serviceProviderId], references: [id], onDelete: Cascade)
  User              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Breakthrough {
  id          String   @id
  userId      String?
  spaceId     String
  title       String
  description String
  category    String
  confidence  Float
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
  Space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  User        User?    @relation(fields: [userId], references: [id])
}

model EmbeddingProvider {
  id          String   @id
  userId      String
  provider    String
  name        String
  apiKey      String
  apiEndpoint String?
  model       String
  dimensions  Int?
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  User        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Experiment {
  id          String   @id
  userId      String?
  spaceId     String
  phase       String
  agentId     String
  agentName   String
  prompt      String
  response    String?
  tokensUsed  Int      @default(0)
  cost        Float    @default(0)
  status      String   @default("PENDING")
  result      String?
  metrics     String?
  grade       Float?
  feedback    String?
  userRating  String?
  cycleNumber Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  User        User?    @relation(fields: [userId], references: [id])
}

model ModelCache {
  id          String   @id
  spaceId     String
  fileName    String
  filePath    String
  fileSize    Int
  downloadUrl String?
  checksum    String?
  description String?
  createdAt   DateTime @default(now())
  Space       Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model ServiceProvider {
  id        String   @id
  userId    String
  provider  String
  name      String
  apiKey    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  Agent     Agent[]
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model Space {
  id                     String         @id
  userId                 String
  name                   String
  description            String?
  initialPrompt          String
  status                 String         @default("INITIALIZING")
  currentPhase           String         @default("PLANNING")
  totalTokens            Int            @default(0)
  totalCost              Float          @default(0)
  useEmbeddings          Boolean        @default(false)
  useGpu                 Boolean        @default(false)
  currentCycle           Int            @default(1)
  setupStatus            String?
  setupError             String?
  setupStep              String?
  defaultNumVariants     Int            @default(3)
  defaultStepsPerVariant Int            @default(25)
  numVariantsMode        String         @default("fixed")
  stepsPerVariantMode    String         @default("fixed")
  createdAt              DateTime       @default(now())
  updatedAt              DateTime
  Breakthrough           Breakthrough[]
  Experiment             Experiment[]
  ModelCache             ModelCache[]
  User                   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  Variant                Variant[]
}

model SystemConfig {
  id          String   @id
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime
}

model User {
  id                String              @id
  email             String              @unique
  password          String
  username          String              @unique
  role              String              @default("USER")
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  Agent             Agent[]
  Breakthrough      Breakthrough[]
  EmbeddingProvider EmbeddingProvider[]
  Experiment        Experiment[]
  ServiceProvider   ServiceProvider[]
  Space             Space[]
}

model Variant {
  id             String        @id
  spaceId        String
  stageId        String
  stageName      String
  cycleNumber    Int           @default(1)
  name           String
  description    String?
  grade          Float?
  feedback       String?
  userRating     String?
  isSelected     Boolean       @default(false)
  order          Int           @default(0)
  status         String        @default("PENDING")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  cacheDownloads String?
  Space          Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  VariantStep    VariantStep[]
}

model VariantStep {
  id          String   @id
  variantId   String
  name        String
  description String?
  order       Int      @default(0)
  result      String?
  grade       Float?
  feedback    String?
  userRating  String?
  status      String   @default("PENDING")
  isAuto      Boolean  @default(true)
  autoConfig  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Variant     Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
}
